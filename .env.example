# Copy this file to ".env" for local development, or set these as environment
# variables in your host's dashboard (Vercel -> Settings -> Environment Variables).
#
# DATABASE_URL is REQUIRED — the app is Postgres-only and raises a clear error at
# startup if it is unset (there is no local SQLite fallback).

# Online Postgres connection string from Supabase:
#   Supabase dashboard -> Project Settings -> Database -> Connection string ->
#   "URI". Use the pooled "Transaction pooler" (port 6543) URI for hosting.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# Secret used to sign login session cookies. Use a long random value.
# Generate one with:  python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Seed-time only (scripts/seed_demo.py): username + private password for the
# edit-capable demo accounts. If DEMO_ADMIN_PASSWORD is unset, the seeder
# generates a random one and prints it once. Never commit real values.
#DEMO_ADMIN_USERNAME=choose-an-admin-username
#DEMO_ADMIN_PASSWORD=choose-a-strong-private-password
